# Server
PORT=4000
NODE_ENV=development

# Supabase PostgreSQL — get from Supabase Dashboard > Settings > Database > Connection String
# Use the "URI" format under "Connection pooling" (Transaction mode)
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-DB-PASSWORD]@HOST/postgres"

# Direct connection URL (used by Prisma migrations only — not pooled)
DIRECT_URL="postgresql://postgres:[YOUR-DB-PASSWORD]@HOST/postgres"

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=replace-with-a-very-long-random-secret-string

# Admin seed credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Business settings
WHATSAPP_NUMBER=2349021627280
BANK_NAME="First Bank Nigeria"
BANK_ACCOUNT_NAME="Olmach Nig Ltd"
BANK_ACCOUNT_NUMBER="0000000000"
DELIVERY_FEE=1500
FREE_DELIVERY_THRESHOLD=50000
